# Server
PORT=5001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/code-reviewer?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Groq API (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Pinecone (https://app.pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=code-reviews
PINECONE_NAMESPACE=default

# OpenAI (for embeddings - text-embedding-3-small)
OPENAI_API_KEY=sk-your_openai_key_for_embeddings

# GitHub (optional)
GITHUB_TOKEN=ghp_your_github_personal_access_token
