{
  "name": "automated-code-reviewer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Full-stack AI-powered automated code reviewer",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "vercel-build": "npm run build -w frontend",
    "start:backend": "npm start -w backend"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
